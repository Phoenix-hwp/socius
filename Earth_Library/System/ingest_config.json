{
  "project": "Earth_Library",
  "version": 1,
  "required_fields": [
    "title",
    "type",
    "source",
    "source_mode",
    "confidence",
    "keywords",
    "content"
  ],
  "optional_fields": [
    "source_url",
    "source_path",
    "note"
  ],
  "source_modes": [
    "notion_page",
    "web_url",
    "markdown_file",
    "conversation",
    "manual"
  ],
  "quality_rules": {
    "duplicate_keyword_overlap_threshold": 0.6,
    "low_confidence_values": [
      "低"
    ],
    "conflict_markers": [
      "冲突",
      "相反",
      "矛盾"
    ]
  }
}
