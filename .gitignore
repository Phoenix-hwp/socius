# ============================================
# 本文件同时作为未来云盘同步忽略规则的预留设计
# 创建：2025-04（Git）. 2026-05-18（新增云盘预留）
# 意图：排除不应跨设备同步的内容（密钥/缓存/回收站）
# 注意：`/.git/` 行在 Git 中不生效，仅作为云盘预留记录
# ============================================

# ============================================
# 个人运行时数据（不进入公开仓库）
# ============================================
Daily-Backups/
Knowledge-Assets/
System-Capabilities/
projects/
inbox/
.claude/
_*.*
bootstrap-*.*
Cursor_Knowledge.code-workspace
temp_validate.py

# 仿真沙箱（训练产物）
Simulation-Sandbox/

# ============================================
# AI Model Shim - 密钥与运行时
# ============================================
.cursor/ai-model-shim/config.json
.cursor/ai-model-shim/*.log
.cursor/ai-model-shim/*.log.*
.cursor/ai-model-shim/.current_model

# ============================================
# 大型二进制文件（通过网盘/U盘分发，不提交 Git）
# ============================================
.cursor/ai-model-shim/node_modules/
.cursor/ai-model-shim/ngrok.exe
.cursor/ai-model-shim/*_bundle.zip
.cursor/ai-model-shim/local-tools/

# ============================================
# Notion 本地密钥（勿提交；自行从 notion.env.example 复制填写）
# ============================================
.cursor/mcp/notion.env

# ============================================
# ============================================
# GitHub 开源屏蔽：以下为本仓库的 Cursor 专属运行时，不进入公开仓库
# 注意：这些目录在本地磁盘上保留，仅被 Git 忽略
# ============================================
.cursor/
adapters/cursor/mcp/
adapters/cursor/hooks/
adapters/cursor/tools/
core/skills/
Simulation-Sandbox/

# ============================================
# 个人运行时数据（不进入公开仓库）
# ============================================
# 知识消化产生的个人协议（core/knowledge/protocols/ 中的模板保留）
Knowledge-Brain/protocols/CP-[0-9]*.md
Knowledge-Brain/protocols/activation.json

# 运行时日志
core/logs/

# 个人报告
reports/

# Checkpoint 归档（个人任务执行记录）
core/data/checkpoints/archive/

# 个人决策队列与消化日志
core/data/Decision-Queue.json
core/data/digest-log.jsonl

# 个人任务追踪（包含大量个人数据）
core/data/Active-Task-Tracker.json
core/data/Pending-Plan-Tracker.json

# 个人运行时日志（行为偏好、决策记录、经验索引等）
core/data/Decision-Log.jsonl
core/data/Behavior-Fit-Log.jsonl
core/data/Behavior-Fit-Log_legacy_archive.jsonl
core/data/Round-Behavior-Hot.jsonl
core/data/Round-Behavior-Warm.jsonl
core/data/experience-index.jsonl
core/data/Decomposition-Log.jsonl
core/data/User-Knowledge-Registry.jsonl

# 测试产物
test_*.txt

# 个人任务计划
plans/

# ============================================
# 运行时缓存与回收站
# ============================================
.trash/
*.pyc
__pycache__/
Skills_Library/skills/**/node_modules/
node_modules/

# Temp scripts and debug output
temp/
socius_config.json

# pip editable install artifacts
phoenix_core.egg-info/
socius.egg-info/

# 操作前安全快照（操作完成后由脚本自动清理，残留视为废数据）
*.bak_*
*.old

# ============================================
# 云盘同步预留：以下规则当前由 Git 管理，未来网盘同步时生效
# ============================================
# Git 内部对象（本地版本库，不参与云盘同步）
/.git/
