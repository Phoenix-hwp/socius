# Rename this file to notion.env and fill your values.
# Get NOTION_TOKEN from Notion: My integrations → your integration → Internal integration secret (secret_ or ntn_ prefix).
# Keep notion.env out of Git; never commit real tokens.

# Required: Notion internal integration token (starts with ntn_ or secret_)
NOTION_TOKEN=

# Optional notes only (for your own memory):
# Share only the allowed parent page with your integration, so MCP is naturally scoped.
NOTION_ALLOWED_PARENT_PAGE_URL=
NOTION_ALLOWED_PARENT_PAGE_ID=
