{
  "_description": "工作流步骤定义注册表 — 每条系统工作流的步骤序列，供 Guard WorkflowIntegrityCheck 比对和 pipeline_runner 编排器执行。升级于 2026-05-27：新增 executor + checkpoint_schema + output_produces 字段，支持代码化编排。",
  "_schema_note": "required: true 的步骤必须完成；false 的步骤可选。Agent 可标注 [⏭ Step_ID: reason] 主动跳过。",
  "_close_check_rules": "收束前自检（强制，跨所有工作流）：每条工作流的最后一步之前，编排器回溯检查所有 required=true 的步骤是否已完成。连续 2 次未经 close_check 即落盘 → Guard 启动时阻断。",
  "_orchestrator_note": "executor 字段值：llm=调 LLM 推理；code=调 Python 函数；hybrid=代码预处理后送入 LLM。checkpoint_fields 定义本步完成时写入 checkpoint JSON 的字段。",
  "workflows": {
    "knowledge_digestion": {
      "name": "知识消化管线",
      "source_file": "core/knowledge/classifier.md",
      "trigger_condition": "用户输入「学习」「消化」「阅读卡片」或关联指令触发知识获取",
      "checkpoint_schema": {
        "task_id": "string",
        "pipeline": "knowledge_digestion",
        "started_at": "ISO datetime",
        "completed_at": "ISO datetime | null",
        "source": {
          "type": "web_search | internal | file | url | user_input",
          "title": "string | null",
          "content": "original source text"
        },
        "phases": {},
        "summary": "string",
        "status": "in_progress | done | failed"
      },
      "steps": [
        {
          "id": "Step_0B",
          "name": "来源去重检查",
          "description": "rg 书名 → 命中则 AskQuestion 跳过/补充，未命中继续",
          "required": true,
          "executor": "hybrid",
          "llm_prompt": "# 来源去重检查\n1. 从 source 文本中提取书名/URL 标识\n2. 用 rg 搜索 digest-log 中是否已存在\n3. 若命中：输出 ask 确认用户意图。若未命中：输出 continue。",
          "code_handler": "_step_0B_dedupe",
          "input_requires": ["source_title", "source_content"],
          "output_produces": ["dedupe_result", "dedupe_decision"],
          "checkpoint_fields": ["dedupe_result", "dedupe_decision"],
          "skip_condition": "source_is_single_concept",
          "skip_reason": "单一概念输入，无需去重",
          "retry_on_failure": 1,
          "success_criteria": "dedupe_decision in ('continue', 'skip_confirmed')",
          "order_in_pipeline": 0
        },
        {
          "id": "Step_0",
          "name": "源分解",
          "description": "将原始知识源拆分为原子观点单元",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 源分解\n将 source 内容拆分为核心知识单元。\n\n## 筛选规则（重要）\n- 只输出**核心知识概念**（需要消化的理论/机制/现象）\n- 排除以下元数据：任务计划、执行步骤、文件路径、产出物声明、概念树更新描述\n- 判断标准：这个 unit 是\"需要学习和内化的知识\"还是\"描述怎么做的操作指令\"？前者保留，后者丢弃\n- target: 3-6 个核心概念 unit\n\n## 输出格式\n每单元输出 {concept_anchor_candidate, summary, cp_type_candidate}。合并共享同一 concept_anchor 的单元。",
          "code_handler": null,
          "input_requires": ["source_content"],
          "output_produces": ["units"],
          "checkpoint_fields": ["units", "decomposition_strategy"],
          "retry_on_failure": 2,
          "success_criteria": "len(units) >= 1",
          "order_in_pipeline": 1
        },
        {
          "id": "Step_0V",
          "name": "视觉源分解",
          "description": "对含图/BPMN/UML的源执行视觉桥接分解",
          "required": false,
          "executor": "hybrid",
          "llm_prompt": "# 视觉源分解\n对 source 中的图执行类型检测→元素提取→歧义标注→置信度自评。产出 text_bridge.json。",
          "code_handler": "_step_0V_visual_decompose",
          "input_requires": ["source_content", "source_images"],
          "output_produces": ["visual_bridges"],
          "checkpoint_fields": ["visual_bridges", "visual_confidence"],
          "skip_condition": "source_has_no_images",
          "skip_reason": "源不含图，跳过视觉分解",
          "retry_on_failure": 1,
          "success_criteria": null,
          "order_in_pipeline": 2
        },
        {
          "id": "Step_1_5",
          "name": "诠释自检",
          "description": "对比 source_text 与 self_recital，确认改写不扭曲原意",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 诠释自检\n对每个 unit 输出三字段：\n1. self_recital：用一句话说出核心主张（≤30字）\n2. concept_anchor_candidates：[候选概念锚]\n3. doubts：理解困惑点，无则 null\nself_recital 必须是人话，不是摘要算法。",
          "code_handler": null,
          "input_requires": ["units"],
          "output_produces": ["self_recitals"],
          "checkpoint_fields": ["self_recitals", "uncertainty_flags"],
          "retry_on_failure": 2,
          "success_criteria": "all units have self_recital",
          "order_in_pipeline": 3
        },
        {
          "id": "Step_1_6",
          "name": "视角自检",
          "description": "检查四视角覆盖",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 视角自检\n对每个 unit 检查是否覆盖了 4 个视角：\n1. 定义视角（是什么）\n2. 操作视角（怎么做）\n3. 反思视角（为什么/什么时候错）\n4. 边界视角（不适用什么时候/什么情况不成立）\n标注缺失视角。",
          "code_handler": null,
          "input_requires": ["units", "self_recitals"],
          "output_produces": ["perspective_coverage"],
          "checkpoint_fields": ["perspective_coverage", "missing_perspectives"],
          "retry_on_failure": 1,
          "success_criteria": null,
          "order_in_pipeline": 4
        },
        {
          "id": "Step_1_4",
          "name": "分类路由",
          "description": "判 cp_type + concept_anchor 落定",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 分类路由\n对每个 unit 判定：\n1. cp_type：六类之一（conceptual/procedural/structural/strategic/experiential/regulatory）\n2. concept_anchor：从 self_recital 中提取的确定概念锚\n3. 合并判决：相邻单元同 concept_anchor → 合并\n输出每个 unit 的分类结果。",
          "code_handler": null,
          "input_requires": ["units", "self_recitals"],
          "output_produces": ["classification_results"],
          "checkpoint_fields": ["classification_results", "merge_decisions"],
          "retry_on_failure": 2,
          "success_criteria": "all units have cp_type assigned",
          "order_in_pipeline": 5
        },
        {
          "id": "P2",
          "name": "四问闸门",
          "description": "逐协议回答 P2 四问：可用/可改进/可组合/可替代",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 四问闸门\n对每个协议回答：\n1. 可用：这条知识在当前系统里立即能用在哪？\n2. 可改进：当前系统的哪个部分可以因它变得更好？\n3. 可组合：它能和哪些已有协议组合产生新的能力？\n4. 可替代：它可以替代当前系统的哪个低效做法？",
          "code_handler": null,
          "input_requires": ["classification_results", "units"],
          "output_produces": ["P2_answers"],
          "checkpoint_fields": ["P2_answers"],
          "retry_on_failure": 1,
          "success_criteria": "all protocols have P2 answers",
          "order_in_pipeline": 6
        },
        {
          "id": "Step_R",
          "name": "读后总结",
          "description": "逐协议三段式总结：①对我有用的 ②暂时没用的 ③建议用于优化系统",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 读后总结\n对每条协议输出三段式总结：\n1. 对我有用的部分（具体观点 + 如何改进当前工作）\n2. 暂时没用的部分（具体观点 + 为何在当前系统方式下用不上）\n3. 建议用于优化系统的建议（如果系统这样做会更好）",
          "code_handler": null,
          "input_requires": ["P2_answers", "classification_results"],
          "output_produces": ["reading_summaries"],
          "checkpoint_fields": ["reading_summaries"],
          "retry_on_failure": 1,
          "success_criteria": "all protocols have reading summary",
          "order_in_pipeline": 7
        },
        {
          "id": "Step_S",
          "name": "全域巡检",
          "description": "以新协议为探针扫描全库概念树碰撞检测",
          "required": true,
          "executor": "hybrid",
          "llm_prompt": "# 全域巡检\n检查新协议与已有协议的：\n1. concept_anchor 冲突（同域重复/可合并）\n2. 概念路径冲突\n3. 分类冲突（同概念不同 cp_type）\n输出碰撞检测报告。",
          "code_handler": "_step_S_scan_concept_tree",
          "input_requires": ["classification_results", "concept_tree"],
          "output_produces": ["collision_report"],
          "checkpoint_fields": ["collision_report", "collision_actions"],
          "retry_on_failure": 1,
          "success_criteria": null,
          "order_in_pipeline": 8
        },
        {
          "id": "P3",
          "name": "主题阅读闸门",
          "description": "同域 ≥3 协议 → 触发 P3 主题阅读合成",
          "required": false,
          "executor": "llm",
          "llm_prompt": "# 主题阅读闸门\n在特定概念域中积累 ≥3 份协议时触发。执行跨协议合成：识别共通模式、互补知识、冲突观点，输出主题阅读报告。",
          "code_handler": null,
          "input_requires": ["classification_results", "concept_tree"],
          "output_produces": ["synthesis_report"],
          "checkpoint_fields": ["synthesis_report"],
          "skip_condition": "domain_protocol_count < 3",
          "skip_reason": "同域协议不足 3 份，不触发合成",
          "retry_on_failure": 1,
          "success_criteria": null,
          "order_in_pipeline": 9
        },
        {
          "id": "D",
          "name": "消化日志落盘",
          "description": "写入 digest-log（含消化概览表 + P2四问 + 改进启示）并更新协议文件与 concept-tree",
          "required": true,
          "executor": "code",
          "llm_prompt": null,
          "code_handler": "_step_D_write_digest_log",
          "input_requires": ["units", "classification_results", "P2_answers", "reading_summaries", "collision_report"],
          "output_produces": ["digest_log_path", "protocols_written", "concept_tree_updated"],
          "checkpoint_fields": ["digest_log_path", "protocols_written", "concept_tree_updated"],
          "retry_on_failure": 1,
          "success_criteria": "digest_log_path exists and protocols_written > 0",
          "order_in_pipeline": 10
        }
      ]
    },
    "task_initiation": {
      "name": "任务启动协议 (TIP)",
      "source_file": ".cursor/rules/task-init-protocol.mdc",
      "trigger_condition": "任何非纯对话/非纯查询类任务启动时",
      "checkpoint_schema": {
        "task_id": "string",
        "pipeline": "task_initiation",
        "started_at": "ISO datetime",
        "completed_at": "ISO datetime | null",
        "user_prompt": "string",
        "phases": {},
        "summary": "string",
        "status": "in_progress | done | failed"
      },
      "steps": [
        {
          "id": "Step_1",
          "name": "任务判类",
          "description": "原子/复合/大系统级 + Cynefin 轻量判域",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 任务判类\n根据用户输入判定任务类型：\n1. 原子任务（单一操作）\n2. 复合任务（多步骤多文件）\n3. 大系统级（涉及架构/迁移）\n同时判定 Cynefin 域：clear/complicated/complex/chaotic",
          "code_handler": null,
          "input_requires": ["user_prompt"],
          "output_produces": ["task_classification", "cynefin_domain"],
          "checkpoint_fields": ["task_classification", "cynefin_domain"],
          "retry_on_failure": 1,
          "success_criteria": "task_classification in ('atomic', 'composite', 'systemic')",
          "order_in_pipeline": 0
        },
        {
          "id": "Step_1_5",
          "name": "渲染器可靠度检查",
          "description": "读 method-reliability-registry",
          "required": true,
          "executor": "code",
          "llm_prompt": null,
          "code_handler": "_step_1_5_check_method_reliability",
          "input_requires": ["task_classification"],
          "output_produces": ["method_status"],
          "checkpoint_fields": ["method_status", "degraded_methods"],
          "retry_on_failure": 0,
          "success_criteria": null,
          "order_in_pipeline": 1
        },
        {
          "id": "Step_4",
          "name": "任务拆解",
          "description": "复合任务拆子任务，逐项评估 P008",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 任务拆解\n将复合任务拆解为可独立完成的子任务序列，逐项给出：\n1. subtask_id\n2. estimated_minutes\n3. output_to（产出路径）\n4. depends_on（上游依赖）\n5. P008 五维预评估（S/Rev/A/E/Auth）",
          "code_handler": null,
          "input_requires": ["user_prompt", "task_classification"],
          "output_produces": ["subtasks", "P008_pre_assessments"],
          "checkpoint_fields": ["subtasks", "P008_pre_assessments"],
          "retry_on_failure": 2,
          "success_criteria": "len(subtasks) >= 1 and all subtasks have P008 assessment",
          "order_in_pipeline": 2
        },
        {
          "id": "Step_4_bis",
          "name": "P008 决策评估",
          "description": "对每个子任务调 mod-decision-framework 评估 7 维度",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# P008 决策评估\n对每个子任务评估完整 7 维度（S/Rev/A/C/E/Auth/K），计算 L_C（偏差差额度量），确定 L0-L3 授权级别。",
          "code_handler": null,
          "input_requires": ["subtasks", "P008_pre_assessments"],
          "output_produces": ["P008_decisions"],
          "checkpoint_fields": ["P008_decisions", "delegation_levels"],
          "retry_on_failure": 2,
          "success_criteria": "all subtasks have delegation level assigned",
          "order_in_pipeline": 3
        },
        {
          "id": "Step_2_KB",
          "name": "KB 预载入",
          "description": "activation.md 过滤器 1 匹配协议",
          "required": false,
          "executor": "code",
          "llm_prompt": null,
          "code_handler": "_step_2_KB_load_activation",
          "input_requires": ["task_classification", "P008_decisions"],
          "output_produces": ["activated_protocols"],
          "checkpoint_fields": ["activated_protocols"],
          "skip_condition": "task_is_trivial",
          "skip_reason": "简单任务无需 KB 预载入",
          "retry_on_failure": 0,
          "success_criteria": null,
          "order_in_pipeline": 4
        },
        {
          "id": "Step_2",
          "name": "结构探针",
          "description": "读目标文件/目录的骨架结构",
          "required": true,
          "executor": "hybrid",
          "llm_prompt": "# 结构探针\n分析目标文件/目录的骨架结构，识别：\n1. 入口文件\n2. 依赖关系\n3. 需要修改的文件范围",
          "code_handler": "_step_2_structure_probe",
          "input_requires": ["user_prompt", "subtasks"],
          "output_produces": ["structure_probe_result"],
          "checkpoint_fields": ["structure_probe_result", "target_files"],
          "retry_on_failure": 1,
          "success_criteria": "len(target_files) > 0",
          "order_in_pipeline": 5
        },
        {
          "id": "Step_3",
          "name": "方案提案",
          "description": "基于探针结果提出执行思路 + AskQuestion 确认",
          "required": true,
          "executor": "llm",
          "llm_prompt": "# 方案提案\n基于结构探针结果，提出执行方案（含步骤序列、潜在风险、预估时间），然后用 ask 向用户确认。",
          "code_handler": null,
          "input_requires": ["structure_probe_result", "subtasks"],
          "output_produces": ["proposal", "user_confirmation"],
          "checkpoint_fields": ["proposal", "user_confirmation"],
          "retry_on_failure": 2,
          "success_criteria": "user_confirmation == 'confirmed'",
          "order_in_pipeline": 6
        },
        {
          "id": "Step_5",
          "name": "执行与验证",
          "description": "按子任务顺序执行 + 逐步验证",
          "required": true,
          "executor": "llm",
          "llm_prompt": null,
          "code_handler": null,
          "input_requires": ["proposal", "subtasks", "target_files"],
          "output_produces": ["execution_results"],
          "checkpoint_fields": ["execution_results", "verification_results"],
          "retry_on_failure": 1,
          "success_criteria": "all subtasks executed",
          "order_in_pipeline": 7
        }
      ]
    },
    "capability_encapsulation": {
      "name": "能力固化封装",
      "source_file": ".cursor/rules/flow-capability-encapsulate.mdc",
      "trigger_condition": "用户输入「封装能力」「固化流程」等指令",
      "checkpoint_schema": {
        "task_id": "string",
        "pipeline": "capability_encapsulation",
        "started_at": "ISO datetime",
        "completed_at": "ISO datetime | null",
        "phases": {},
        "summary": "string",
        "status": "in_progress | done | failed"
      },
      "steps": [
        { "id": "Step_1", "name": "提取步骤序列", "description": "从对话中提取操作序列", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 0 },
        { "id": "Step_2", "name": "复杂度判定", "description": "判步骤数/分支/参数 → 分流 L1/L2/L3", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 1 },
        { "id": "Step_3", "name": "预览产物", "description": "展示生成内容 + dependency + write_scope", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 2 },
        { "id": "Step_4", "name": "确认并落盘", "description": "AskQuestion → 写入文件 + 登记", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 3 }
      ]
    },
    "simulation_execution": {
      "name": "仿真执行",
      "source_file": ".cursor/rules/flow-simulation-execute.mdc",
      "trigger_condition": "用户输入「仿真」「模拟」「沙箱仿真」等指令",
      "checkpoint_schema": {
        "task_id": "string",
        "pipeline": "simulation_execution",
        "started_at": "ISO datetime",
        "completed_at": "ISO datetime | null",
        "phases": {},
        "summary": "string",
        "status": "in_progress | done | failed"
      },
      "steps": [
        { "id": "Phase_1", "name": "启动简报", "description": "任务背景 + 预期学习点 + 生成 .plan.json", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 0 },
        { "id": "Phase_2", "name": "沙箱执行", "description": "写保护激活 → 逐步模拟 → 记录日志", "required": true, "executor": "llm", "llm_prompt": null, "code_handler": null, "input_requires": [], "output_produces": [], "checkpoint_fields": [], "retry_on_failure": 1, "success_criteria": null, "order_in_pipeline": 1 },
