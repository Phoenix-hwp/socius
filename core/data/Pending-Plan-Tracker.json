{
  "meta": {
    "description": "待办计划追踪 — 支持备忘关联、每日首次提醒（手动「待办」指令触发）、自动完成检测。长文本已外迁到 plans/ 目录，JSON 仅保留短标识 + 文件指针。",
    "last_reminded": "",
    "data_governance": "符合原则1：description >50字的 plan 已外迁到 plans/plans/<id>.md，JSON 仅存 id + topic + status + file_pointer",
    "reminder_rules": {
      "overdue": "planned_date <= 今天 + status=pending → 每日首次交互弹窗（用户输入「待办」手动触发），同日跳过",
      "upcoming": "planned_date 在未来 3 天 + status=pending → 每日首次交互弹窗合并展示",
      "keyword_match": "对话命中 resume_keywords → 回复末尾追加「⏰ 待办关联」提示（加粗醒目，不阻断）",
      "auto_complete": "收束时检测待办项（pending + in_progress）是否实际完成 → AskQuestion 确认（见 flow-behavior-auto-receipt.mdc 步骤 C#8）",
      "manual_cancel": "'取消待办 Pxxx' 或交互弹窗 [跳过此项] → 不变更 tracker.json（跳过只跳过本次提醒，不取消）",
      "command": "输入「待办」→ 手动触发待办查看/操作弹窗链（同交互流程）",
      "tep_sim_routing": "id 匹配 V012-DRILL-* → flow-v012-drill-bridge.mdc；mark-done 须 pipeline 全链路验收",
      "cancel_policy": {
        "rule": "Agent 将待办状态变更为 cancelled 时，必须先用 AskQuestion 向用户确认原因。不得静默取消。",
        "required_fields": [
          "cancel_reason"
        ],
        "enforcement": "gateway-command-router.mdc + todo_reminder hook 双端拦截",
        "created": "2026-05-20"
      }
    },
    "memo_linkage": {
      "direction": "备忘不主动生成待办；用户手动关联；多对一（多待办可指同一备忘）",
      "cross_reference": "查看备忘时自动匹配 tracker.json source_memo.path，展示关联待办及其状态",
      "no_auto_write": "待办完成不回写备忘文件，仅更新 tracker.json 状态"
    },
    "pending_fields": {
      "source_task": "关联的子任务 ID（来自 Active-Task-Tracker），null = 无关联",
      "parent_task": "父任务 ID（TEP 拆解的根任务），null = 独立待办。子任务继承父任务的 deadline",
      "deadline": "最终截止日期（用户指定），null = 无截止约束",
      "planned_completion": "TEP 计划完成日（deadline - review_gap_days），阶段一计算，阶段四落盘",
      "review_gap_days": "预留 review 天数（默认：1-3子任务=1天, 4-6=2天, 7+=3天，用户可改）",
      "estimated_minutes": "预估耗时（分钟），阶段二 LLM#2 输出，阶段三负载检查用",
      "method": "锁定方法声明（不可变）：一句话描述本步核心方法，连载恢复时注入上下文",
      "input_from": "上游依赖：数组[{from_task, asset}]。空数组=无依赖",
      "output_to": "本步产出物路径或键，连载恢复和依赖检查用",
      "tool_lock": "锁定工具关键词，null = 自由选择"
    },
    "vision_fields": {
      "trigger_condition": "什么事件发生时，此愿景应被重新审视（不主动弹窗提醒，仅在用户说'回顾远期愿景'或系统审计检测到相关能力变更时提示）",
      "status": "固定为 vision（远期预留，无 planned_date）"
    }
  },
