      "system": "系统自身能力，管理仓库/规则/知识库/待办，被系统流程（sessionStart/pull/收束）调用",
      "general": "通用能力，跨项目可复用",
      "role": "领域能力，特定场景按需加载"
    },
    "optional_fields": {
      "design_quality_score": "0-7，基于 Skill 设计自检清单（skill-design-checklist.md）的七特征评分，可选",
      "capability_type": "能力类型数组（data_collection / data_analysis / visualization / document_generation / diagramming / decision_support / code_generation / knowledge_retrieval），声明本 Skill 提供的能力类型，用于 template-generator L2/L3 匹配，可选",
      "input_schema": "标准输入接口声明，可选（待 L2/L3 运行时落地后填充）",
      "output_schema": "标准输出接口声明，可选（待 L2/L3 运行时落地后填充）",
      "side_effects": "副作用声明数组（如 notion_write / file_write / git_worktree / external_api），用于执行层安全审查，可选",
      "known_params": "从程序性协议提炼的已知参数模板，template-generator L2 产物写入点，可选"
    },
    "created": "2026-05-12",
    "updated": "2026-05-23"
  },
  "frequency_tiers": {
    "常用": {
      "definition": "日常高频使用，常驻加载",
      "retention": "永久保留"
    },
    "高频": {
      "definition": "项目期高频使用，项目期保留",
      "retention": "项目结束后评估"
    },
    "低频": {
      "definition": "特定 agent 或场景使用",
      "retention": "按需加载，可休眠"
    },
    "特定": {
      "definition": "一次性任务获取，用完归档",
